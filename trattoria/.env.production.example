# Feature Flags para Producción
# 
# Copia este archivo a .env.production y configura las features que quieres habilitar
# Las features NO configuradas o con valor 'false' mostrarán el overlay "Coming Soon"
# 
# En desarrollo (NODE_ENV=development), todas las features están habilitadas automáticamente

# ===== RELEASE 1 - MVP Operativo =====
# Estas features deberían estar habilitadas en producción desde el inicio
# (No necesitan variable de entorno, están siempre activas)

# ===== RELEASE 2 - Gestión Financiera =====
# Habilitar cuando estén listas estas funcionalidades:

# Reportes Analytics completos (gráficos, KPIs avanzados)
NEXT_PUBLIC_FEATURE_ANALYTICS=false

# Módulo de Stock/Insumos (ABM, alertas, movimientos)
NEXT_PUBLIC_FEATURE_INSUMOS=false

# Edición de Egresos (vs solo lectura)
NEXT_PUBLIC_FEATURE_EGRESOS_EDIT=false

# Edición de Ingresos
NEXT_PUBLIC_FEATURE_INGRESOS_EDIT=false

# ===== RELEASE 3 - Optimización =====
# Estas features son para la fase 3:

# Módulo de Recetas (ingredientes, costos, márgenes)
NEXT_PUBLIC_FEATURE_RECETAS=false

# Gestión de Empleados
NEXT_PUBLIC_FEATURE_EMPLEADOS=false

# Sistema de Promociones
NEXT_PUBLIC_FEATURE_PROMOCIONES=false

# ===== INSTRUCCIONES DE USO =====
# 
# Para habilitar una feature en producción:
# 1. Edita .env.production
# 2. Cambia 'false' a 'true' en la feature deseada
# 3. Commitea y despliega en Vercel
# 4. Vercel recargará con las nuevas variables de entorno
# 
# Ejemplo - Habilitar Analytics:
# NEXT_PUBLIC_FEATURE_ANALYTICS=true
# 
# En Vercel:
# Settings > Environment Variables > agregar las variables con valor 'true'
