# =============================================================================
# DATABASE
# =============================================================================
# Neon PostgreSQL Connection String
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# =============================================================================
# FIREBASE CLIENT SDK (Frontend - Public)
# =============================================================================
# Estas variables son expuestas al cliente (browser)
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# =============================================================================
# FIREBASE ADMIN SDK (Backend - Private)
# =============================================================================
# Estas variables NUNCA se exponen al cliente
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
# Duración de la sesión en días (default: 5)
SESSION_MAX_AGE_DAYS="5"

# =============================================================================
# BOOTSTRAP ADMIN (Opcional)
# =============================================================================
# Habilita el auto-aprovisionamiento de administradores
BOOTSTRAP_ENABLED="true"
# Emails que se convertirán automáticamente en ADMIN al iniciar sesión
BOOTSTRAP_ADMIN_EMAILS="admin@example.com,otro-admin@example.com"

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Next.js maneja esto automáticamente, pero puedes especificarlo
# NODE_ENV="development"
